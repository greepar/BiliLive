<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BiliLive.App"
             xmlns:local="using:BiliLive"
             xmlns:behaviors="clr-namespace:BiliLive.Behaviors"
             xmlns:m3="https://github.com/greepar/md3"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/avalonia-logo.ico" 
                      Clicked="TrayIcon_OnClicked"
                      ToolTipText="Avalonia Tray Icon ToolTip">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Settings">
                            <NativeMenu>
                                <NativeMenuItem Header="Open"   />
                                <NativeMenuItem Header="Start with system"   />
                                <NativeMenuItemSeparator />
                                <NativeMenuItem Header="Exit"  />
                            </NativeMenu>
                        </NativeMenuItem>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
    
    
    <Application.Resources>
        <ResourceDictionary>
            
            <FontFamily x:Key="Xiaolai">
                avares://BiliLive/Assets/Fonts/Xiaolai-Regular.ttf#Xiaolai
            </FontFamily>

            
            <FontFamily x:Key="NotoRegular">
                avares://BiliLive/Assets/Fonts/NotoSans-Regular.ttf#Noto Sans,
                avares://BiliLive/Assets/Fonts/NotoSansSC-Regular.ttf#Noto Sans SC Regular
            </FontFamily>
            
            <FontFamily x:Key="NotoMedium">
                avares://BiliLive/Assets/Fonts/NotoSans-Medium.ttf#Noto Sans Medium,
                avares://BiliLive/Assets/Fonts/NotoSansSC-Medium.ttf#Noto Sans SC Medium
            </FontFamily>
            
            <FontFamily x:Key="RobotoRegular">
                avares://BiliLive/Assets/Fonts/Roboto-Regular.ttf#Roboto
            </FontFamily>
            
            <FontFamily x:Key="RobotoMedium">
                avares://BiliLive/Assets/Fonts/Roboto-Medium.ttf#Roboto Medium
            </FontFamily>
            
            <ResourceDictionary.MergedDictionaries>
                <!-- All M3 themes are now provided by <m3:Material3Theme/> below. -->
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
    
    <Application.Styles>
        <m3:Material3Theme />

        <Style Selector="ToggleSwitch:checked /template/ Border#SwitchKnobBounds">
            <Setter Property="Background" Value="{DynamicResource Primary}" />
        </Style>
        
        <Style Selector="Window,UserControl">
            <Setter Property="FontFamily" Value="{StaticResource NotoRegular}"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Transitions">
                <Transitions>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ScrollViewer">
            <Setter Property="behaviors:SmoothScrollBehavior.IsEnabled" Value="True"/>
            <Setter Property="IsScrollInertiaEnabled" Value="True"/>
        </Style>
        <Style Selector="m3|SvgBox">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Fill" Easing="CubicEaseInOut" Duration="0.3"/>
                </Transitions>
            </Setter>
        </Style>
    </Application.Styles>

    

    
    
</Application>
