<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BiliLive.Views.MainWindow.Controls"
             xmlns:m3="https://github.com/greepar/md3"
             xmlns:converters="clr-namespace:BiliLive.Converters"
             mc:Ignorable="d"
             x:Class="BiliLive.Views.MainWindow.Controls.AccountsView"
             x:DataType="vm:AccountsViewModel"
             FontFamily="{StaticResource NotoMedium}">

    <Design.DataContext>
        <vm:AccountsViewModel />
    </Design.DataContext>

    <Border Name="RootCard"
            Focusable="True"
            Width="520"
            MinHeight="220"
            CornerRadius="22"
            ClipToBounds="True"
            Background="{DynamicResource Surface}"
            BoxShadow="0 12 36 0 #36000000">
        <Grid>
            <Border Background="{DynamicResource PrimaryContainer}"
                    Opacity="0.18"
                    Height="74"
                    VerticalAlignment="Top"
                    IsHitTestVisible="False"/>

            <Grid Margin="22" ColumnDefinitions="1.05*,1.25*" ColumnSpacing="18">
                <Border Name="AccountBorder"
                        Grid.Column="0"
                        Opacity="{Binding IsInLoginProcess,Converter={converters:BoolToOpacityConverter}}">
                    <Border.RenderTransform>
                        <TranslateTransform X="0" />
                    </Border.RenderTransform>
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                        </Transitions>
                    </Border.Transitions>

                    <Grid RowDefinitions="Auto,Auto" RowSpacing="18">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0"
                                    Height="72" Width="72"
                                    CornerRadius="36"
                                    ClipToBounds="True"
                                    Background="{DynamicResource SurfaceContainerHigh}">
                                <Image Width="72" Height="72"
                                       RenderOptions.BitmapInterpolationMode="HighQuality"
                                       Source="{Binding UserFace}" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="16 3 0 0"
                                        Spacing="5"
                                        VerticalAlignment="Center">
                                <TextBlock Text="当前账号"
                                           FontSize="12"
                                           Foreground="{DynamicResource OnSurfaceVariant}"/>
                                <TextBlock FontSize="19"
                                           FontWeight="Bold"
                                           Text="{Binding GeneralState.UserName}"/>
                                <Border HorizontalAlignment="Left"
                                        CornerRadius="12"
                                        Padding="9 4"
                                        Background="{DynamicResource SurfaceContainerHigh}">
                                    <TextBlock FontSize="12"
                                               Foreground="{DynamicResource OnSurfaceVariant}"
                                               Text="{Binding GeneralState.UserId,StringFormat=UID {0}}" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Classes="Tonal"
                                    Height="42"
                                    CornerRadius="18"
                                    Click="AccountBtn_OnClick"
                                    Command="{Binding LoginStatusConverterCommand}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="7">
                                    <m3:SvgBox PathData="{m3:Geometry {x:Static m3:Icons.Add}}"
                                               Height="17"
                                               VerticalAlignment="Center"
                                               Fill="{DynamicResource OnSecondaryContainer}" />
                                    <TextBlock VerticalAlignment="Center" Text="更换账号" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1"
                                    Name="DelAltBtn"
                                    Classes="Text"
                                    Height="42"
                                    Width="48"
                                    CornerRadius="18"
                                    Background="{DynamicResource SurfaceContainerHigh}"
                                    Command="{Binding DelAccountCommand}"
                                    CommandParameter="{x:True}"
                                    Click="DelBtn_OnClick">
                                <m3:SvgBox PathData="{m3:Geometry {x:Static m3:Icons.Delete}}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Fill="{DynamicResource OnSurface}"
                                           Height="18"/>
                            </Button>

                            <Button Grid.Column="2"
                                    Name="DiscardBtn"
                                    Classes="Text"
                                    Height="42"
                                    Width="0"
                                    CornerRadius="18"
                                    Background="{DynamicResource SurfaceContainerHigh}"
                                    Command="{Binding DelAccountCommand}"
                                    CommandParameter="{x:False}"
                                    Click="DelBtn_OnClick">
                                <Button.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Width" Duration="0:0:0.22" Easing="CubicEaseOut" />
                                    </Transitions>
                                </Button.Transitions>
                                <m3:SvgBox PathData="{m3:Geometry {x:Static m3:Icons.Error}}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Height="18" Width="18"
                                           Fill="{DynamicResource OnSurface}" />
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <Border Name="AccountTipsBorder"
                        Grid.Column="1"
                        Opacity="{Binding IsInLoginProcess,Converter={converters:BoolToOpacityConverter}}">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                        </Transitions>
                    </Border.Transitions>

                    <StackPanel Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="账号切换"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBlock Text="当前主账号只负责开播、获取直播间信息和基础操作。需要更换主账号时，请使用扫码登录重新授权。"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource OnSurfaceVariant}"/>
                        <Border CornerRadius="16"
                                Padding="14"
                                Background="{DynamicResource SurfaceContainerLow}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="提示" FontWeight="SemiBold"/>
                                <TextBlock Text="自动服务中的小号 Alts 独立管理，不会和主账号切换混用。"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Foreground="{DynamicResource OnSurfaceVariant}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Name="QrLoginBorder"
                        Grid.Column="1"
                        ZIndex="1"
                        MinHeight="176"
                        Opacity="{Binding !IsInLoginProcess,Converter={converters:BoolToOpacityConverter}}"
                        IsHitTestVisible="{Binding IsInLoginProcess}">
                    <Border.RenderTransform>
                        <TranslateTransform X="18" />
                    </Border.RenderTransform>
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="ExponentialEaseOut" />
                        </Transitions>
                    </Border.Transitions>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                        <Border Grid.Column="0"
                                CornerRadius="16"
                                ClipToBounds="True"
                                BorderThickness="6"
                                BorderBrush="{DynamicResource SurfaceContainerHigh}"
                                Background="{DynamicResource SurfaceContainerHigh}"
                                Width="148" Height="148">
                            <Image Source="{Binding QrCodePic}"/>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center">
                            <Border Width="42" Height="42"
                                    CornerRadius="21"
                                    Background="{DynamicResource Primary}"
                                    HorizontalAlignment="Left">
                                <m3:SvgBox Width="21" Height="21"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Fill="{DynamicResource OnPrimary}"
                                           PathData="{m3:Geometry {x:Static m3:Icons.Qr}}"/>
                            </Border>

                            <StackPanel Spacing="4">
                                <TextBlock Text="扫码登录"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                                <TextBlock Text="使用哔哩哔哩 App 扫描二维码完成登录。"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           Foreground="{DynamicResource OnSurfaceVariant}"/>
                            </StackPanel>

                            <Button Classes="Text"
                                    Height="36"
                                    HorizontalAlignment="Left"
                                    CornerRadius="16"
                                    Background="{DynamicResource SurfaceContainerHigh}"
                                    Command="{Binding CancelLoginCommand}"
                                    Click="AccountBtn_OnClick">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <m3:SvgBox Width="18" Height="18"
                                               PathData="{m3:Geometry {x:Static m3:Icons.Back}}"/>
                                    <TextBlock VerticalAlignment="Center" Text="返回账号"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
