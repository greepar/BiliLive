<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BiliLive.Views.MainWindow.Pages.About"
             xmlns:md3="https://github.com/greepar/md3"
             xmlns:biliLive="clr-namespace:BiliLive"
             xmlns:res="clr-namespace:BiliLive.Resources"
             mc:Ignorable="d" d:DesignWidth="870" d:DesignHeight="535"
             x:Class="BiliLive.Views.MainWindow.Pages.About.AboutView"
             x:DataType="vm:AboutViewModel">
   
    <Design.DataContext>
        <vm:AboutViewModel/>
    </Design.DataContext>
    
    <Grid VerticalAlignment="Stretch"
          HorizontalAlignment="Stretch"
          RowDefinitions="*,Auto"
          >
        <Border Grid.Row="0"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <StackPanel Spacing="20">
                <Border CornerRadius="12" Background="{DynamicResource SurfaceContainer}" Height="30">
                    <StackPanel Orientation="Horizontal">
                        <!-- 图标 -->
                        <Border CornerRadius="12" Background="{DynamicResource Primary}" >
                            <SvgBox Height="20" Width="20"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Fill="{DynamicResource InverseOnSurface}"
                                    Margin="6 0 6 0" PathData="{res:Geometry {x:Static res:MdIcons.Notice}}"/>
                        </Border>

                        <TextBlock VerticalAlignment="Center" Margin="5 0 0 0">
                            关于界面仍在设计中... 以下为开发测试组件展示
                        </TextBlock>
                    </StackPanel>
                </Border>                
                <StackPanel Orientation="Horizontal"
                            Spacing="15">
                    <!-- <ToggleSwitch></ToggleSwitch> -->
                    <TextBox Watermark="Title" Width="100" Text="hello"></TextBox>
                    <Button Classes="Elevated"> Elevated</Button>
                    <Button Classes="Outline"> Outlined</Button>
                    <Button Classes="Tonal"> Tonal</Button>
                    <Button Classes="Filled"> Filled</Button>
                    <Button Classes="Text"> Text</Button>
                </StackPanel>
             
                
               <StackPanel Orientation="Horizontal">
                   <md3:ProgressRing Width="40" Height="40" Speed="180" SweepAngle="170"
                                 Stroke="{DynamicResource Primary}"
                                 StrokeThickness="6"
                                 IsRotating="True"/>
                   <md3:ProgressRing Width="40" Height="40" Speed="180" SweepAngle="180"
                                 Stroke="{DynamicResource Primary}"
                                 StrokeThickness="6"
                                 IsRotating="False"/>
                   <TextBlock Margin="10 0 0 0" VerticalAlignment="Center">Loading ....</TextBlock>
                   <Button Margin="10 0 0 0" 
                           Classes="Elevated"
                           Command="{Binding GetLiveCookieCommand}">[测试] 获取直播姬Cookie登录</Button>
               </StackPanel>
            </StackPanel>
     
        </Border>
        
        <Border Grid.Row="1"
                IsVisible="{ x:Static biliLive:BuildInfo.IsDebugMode }"
                CornerRadius="12"
                Background="{DynamicResource SurfaceContainer}">
            <Grid Margin="5">
                <StackPanel>
                    <TextBlock Margin="5 0 0 0" Text="Debug Tools"/>
                    <StackPanel Orientation="Horizontal"
                                Spacing="10">
                        <CheckBox Theme="{StaticResource MdCheckBox}" 
                                  Command="{Binding SetTopMostWindowCommand}"
                                  CommandParameter="{Binding $self.IsChecked}"
                                  Content="SetTopMost"/>
                        <Button Classes="Elevated"
                                Command="{Binding OpenCurrentFolderCommand}"
                                IsVisible="{ x:Static biliLive:BuildInfo.IsDebugMode }" >
                            <StackPanel Spacing="5" Orientation="Horizontal" HorizontalAlignment="Center">
                                <SvgBox Height="18" Width="18" Margin="3 0 0 0" PathData="{res:Geometry {x:Static res:MdIcons.Windowed}}"/>
                                <TextBlock VerticalAlignment="Center" FontSize="11">Open Runtime Folder</TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding TestCommand}">test</Button>
                    </StackPanel>
      
                    <!-- debug mode -->
                    <!-- <Grid IsVisible="{ x:Static biliLive:BuildInfo.IsDebugMode }" Margin="0 0 5 0"  VerticalAlignment="Center" HorizontalAlignment="Right"> -->
                    <!--     <Border Background="{DynamicResource OnSurface}" CornerRadius="8" -->
                    <!--             Height="20" Width="80" -->
                    <!--             VerticalAlignment="Stretch" -->
                    <!--             Opacity="0.3" -->
                    <!--     > -->
                    <!--     </Border> -->
                    <!--     <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" -->
                    <!--                FontSize="10" FontWeight="Regular" -->
                    <!--                Foreground="{DynamicResource OnSurface}" -->
                    <!--                Text="Debug Mode" /> -->
                    <!-- </Grid> -->
                            
              
                    <!-- debug mode -->
                </StackPanel>
            </Grid>
        </Border>
       
    </Grid>
  
</UserControl>
