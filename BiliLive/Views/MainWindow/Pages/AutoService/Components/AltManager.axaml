<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BiliLive.Views.MainWindow.Pages.AutoService.Components"
        xmlns:m3="https://github.com/greepar/md3"
        mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="360"
        x:Class="BiliLive.Views.MainWindow.Pages.AutoService.Components.AltManager"
        x:DataType="vm:AltManagerViewModel"
        Title="AltsManager"
        ShowInTaskbar="False"
        WindowDecorations="None"
        WindowStartupLocation="CenterOwner"
        TransparencyLevelHint="Transparent"
        TransparencyBackgroundFallback="Transparent"
        Background="Transparent"
        SizeToContent="WidthAndHeight">

    <Design.DataContext>
        <vm:AltManagerViewModel/>
    </Design.DataContext>

    <Border Name="RootCard"
            Width="560"
            CornerRadius="24"
            ClipToBounds="True"
            Background="{DynamicResource Surface}"
            BoxShadow="0 16 42 0 #42000000">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
        </Border.RenderTransform>
        <Border.Styles>
            <Style Selector="Border#RootCard">
                <Style.Animations>
                    <Animation Duration="0:0:0.24" Easing="CubicEaseOut" FillMode="Forward">
                        <KeyFrame Cue="0%">
                            <Setter Property="Opacity" Value="0"/>
                            <Setter Property="ScaleTransform.ScaleX" Value="0.96"/>
                            <Setter Property="ScaleTransform.ScaleY" Value="0.96"/>
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="Opacity" Value="1"/>
                            <Setter Property="ScaleTransform.ScaleX" Value="1"/>
                            <Setter Property="ScaleTransform.ScaleY" Value="1"/>
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Border.Styles>

        <Grid RowDefinitions="Auto,*">
            <Border Grid.Row="0"
                    Height="82"
                    Background="{DynamicResource PrimaryContainer}"
                    Opacity="0.28"
                    IsHitTestVisible="False"/>

            <Grid Grid.RowSpan="2" Margin="24" RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0"
                            Width="52" Height="52"
                            CornerRadius="18"
                            Background="{DynamicResource Primary}">
                        <m3:SvgBox Width="26" Height="26"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Fill="{DynamicResource OnPrimary}"
                                   PathData="{m3:Geometry {x:Static m3:Icons.AutoService}}"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="14 0 0 0" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="小号管理" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="添加或编辑自动服务使用的小号、弹幕和代理设置。"
                                   FontSize="12"
                                   Foreground="{DynamicResource OnSurfaceVariant}"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Width="38" Height="38"
                            CornerRadius="19"
                            Padding="0"
                            Background="{DynamicResource SurfaceContainerHigh}"
                            Theme="{StaticResource MdButton}"
                            Click="Button_OnClick">
                        <m3:SvgBox Width="18" Height="18"
                                   Fill="{DynamicResource OnSurface}"
                                   PathData="{m3:Geometry {x:Static m3:Icons.Error}}"/>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="18">
                    <StackPanel Grid.Column="0" Width="168" Spacing="10">
                        <Border Width="154" Height="154"
                                CornerRadius="18"
                                Padding="7"
                                ClipToBounds="True"
                                Background="{DynamicResource SurfaceContainerHigh}">
                            <Border CornerRadius="13" ClipToBounds="True">
                                <Image Source="{Binding QrCodePic}"/>
                            </Border>
                        </Border>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    Height="36"
                                    CornerRadius="16"
                                    Background="{DynamicResource SurfaceContainerLow}">
                                <TextBlock Text="扫码添加小号"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"/>
                            </Border>
                            <Button Grid.Column="1"
                                    Width="36" Height="36"
                                    CornerRadius="16"
                                    Padding="0"
                                    Background="{DynamicResource SurfaceContainerHigh}"
                                    Theme="{StaticResource MdButton}"
                                    Command="{Binding EditCookieCommand}">
                                <m3:SvgBox Height="18" Width="18"
                                           PathData="{m3:Geometry {x:Static m3:Icons.Edit}}"
                                           Fill="{DynamicResource OnSurface}"/>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                        <Border Grid.Row="0" CornerRadius="18" Padding="14" Background="{DynamicResource SurfaceContainerLow}">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="登录凭据" FontWeight="SemiBold"/>
                                        <TextBlock Text="扫码成功后会自动填入，也可以手动粘贴 Cookie 后验证。"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource OnSurfaceVariant}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Height="34"
                                            CornerRadius="16"
                                            Padding="14 0"
                                            Classes="Tonal"
                                            IsEnabled="{Binding !AllowDoneClose}"
                                            Command="{Binding CheckCookieCommand}">
                                        验证
                                    </Button>
                                </Grid>

                                <TextBox Grid.Row="1"
                                         Height="38"
                                         CornerRadius="16"
                                         PlaceholderText="请输入 Cookie"
                                         Text="{Binding CookieValue}"
                                         IsEnabled="{Binding !AllowDoneClose}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" CornerRadius="18" Padding="14" Background="{DynamicResource SurfaceContainerLow}">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <TextBlock Text="弹幕与礼物" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <ToggleSwitch Grid.Column="1"
                                                  RenderTransform="scale(0.82)"
                                                  OnContent="发送牛蛙 x2"
                                                  OffContent="发送牛蛙 x2"
                                                  IsChecked="{Binding IsSendGift}"/>
                                </Grid>

                                <DockPanel Grid.Row="1" LastChildFill="True">
                                    <Button DockPanel.Dock="Left"
                                            Width="38" Height="38"
                                            Margin="0 0 8 0"
                                            CornerRadius="16"
                                            Padding="0"
                                            Background="{DynamicResource SecondaryContainer}"
                                            Theme="{StaticResource MdButton}"
                                            Command="{Binding AddDanmakuCommand}">
                                        <m3:SvgBox Width="18" Height="18"
                                                   Fill="{DynamicResource OnSecondaryContainer}"
                                                   PathData="{m3:Geometry {x:Static m3:Icons.Add}}"/>
                                    </Button>
                                    <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding DanmakuList}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="*,Auto" Width="150">
                                                        <TextBox Grid.Column="0"
                                                                 Height="38"
                                                                 CornerRadius="16"
                                                                 Text="{Binding Text}"/>
                                                        <Button Grid.Column="1"
                                                                Width="34" Height="34"
                                                                Margin="6 2 0 2"
                                                                CornerRadius="15"
                                                                Padding="0"
                                                                Theme="{StaticResource MdButton}"
                                                                Background="{DynamicResource SurfaceContainerHigh}"
                                                                Command="{Binding RemoveCommand}">
                                                            <m3:SvgBox Width="16" Height="16"
                                                                       Fill="{DynamicResource OnSurface}"
                                                                       PathData="{m3:Geometry {x:Static m3:Icons.Delete}}"/>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" CornerRadius="18" Padding="14" Background="{DynamicResource SurfaceContainerLow}">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                                <TextBlock Text="HTTP Proxy" FontWeight="SemiBold"/>
                                <Grid Grid.Row="1" ColumnDefinitions="1.15*,*,*" ColumnSpacing="8">
                                    <TextBox Grid.Column="0" Height="38" CornerRadius="16" PlaceholderText="IP Address" Text="{Binding ProxyAddress}"/>
                                    <TextBox Grid.Column="1" Height="38" CornerRadius="16" PlaceholderText="Username" Text="{Binding ProxyUsername}"/>
                                    <TextBox Grid.Column="2" Height="38" CornerRadius="16" PlaceholderText="Password" Text="{Binding ProxyPassword}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource OnSurfaceVariant}"
                               Text="确认后会保存为自动服务的小号，不会替换当前主账号。"/>
                    <Button Grid.Column="1"
                            Height="40"
                            Padding="22 0"
                            CornerRadius="18"
                            Classes="Tonal"
                            Click="Button_OnClick">
                        Cancel
                    </Button>
                    <Button Grid.Column="2"
                            Name="DoneBtn"
                            Height="40"
                            Padding="24 0"
                            CornerRadius="18"
                            Classes="Filled"
                            IsEnabled="{Binding AllowDoneClose}"
                            Click="Button_OnClick">
                        Done
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
