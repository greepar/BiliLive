<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:components="clr-namespace:BiliLive.Views.MainWindow.Pages.AutoService.Components"
             xmlns:utility="clr-namespace:BiliLive.Views.MainWindow.Pages.AutoService.Components.Utility"
             mc:Ignorable="d" d:DesignWidth="328" d:DesignHeight="520"
             x:DataType="components:TimePickerViewModel"
             x:Class="BiliLive.Views.MainWindow.Pages.AutoService.Components.TimePickerView">

    <Design.DataContext>
        <components:TimePickerViewModel/>
    </Design.DataContext>

    <Border x:Name="RootCard"
            Width="328"
            Padding="24"
            CornerRadius="28"
            Background="{DynamicResource SurfaceContainerHigh}"
            BoxShadow="{StaticResource M3Elevation3}"
            ClipToBounds="False"
            RenderTransformOrigin="50%,0%"
            Opacity="0">

        <Border.RenderTransform>
            <TransformOperations>scale(0.92) translateY(-12px)</TransformOperations>
        </Border.RenderTransform>

        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity"
                                  Duration="{StaticResource M3DurationMedium2}"
                                  Easing="{StaticResource M3EasingEmphasizedDecelerate}"/>
                <TransformOperationsTransition Property="RenderTransform"
                                               Duration="{StaticResource M3DurationMedium4}"
                                               Easing="{StaticResource M3EasingEmphasizedDecelerate}"/>
            </Transitions>
        </Border.Transitions>

        <Grid RowDefinitions="Auto,Auto,Auto,Auto">

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="Select time"
                       FontSize="{StaticResource M3LabelMediumFontSize}"
                       FontWeight="{StaticResource M3LabelMediumFontWeight}"
                       Foreground="{DynamicResource OnSurfaceVariant}"
                       Margin="0,0,0,20"/>

            <!-- Time fields + AM/PM segmented -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="8"
                        Margin="0,0,0,36">

                <Button Theme="{StaticResource M3TimeFieldButton}"
                        Classes.Selected="{Binding IsHourMode}"
                        Command="{Binding SetModeCommand}"
                        CommandParameter="Hour"
                        Content="{Binding DisplayHour, StringFormat='00'}"/>

                <TextBlock Text=":"
                           FontSize="57"
                           Foreground="{DynamicResource OnSurface}"
                           VerticalAlignment="Center"/>

                <Button Theme="{StaticResource M3TimeFieldButton}"
                        Classes.Selected="{Binding IsMinuteMode}"
                        Command="{Binding SetModeCommand}"
                        CommandParameter="Minute"
                        Content="{Binding Minute, StringFormat='00'}"/>

                <Border BorderBrush="{DynamicResource Outline}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Width="52"
                        Height="80"
                        Margin="4,0,0,0"
                        ClipToBounds="True">
                    <Grid RowDefinitions="*,1,*">
                        <Button Grid.Row="0"
                                Theme="{StaticResource M3SegmentedAmPmButton}"
                                Classes.Selected="{Binding IsAm}"
                                Content="AM"
                                Command="{Binding SetAmPmCommand}"
                                CommandParameter="AM"/>
                        <Border Grid.Row="1" Background="{DynamicResource Outline}"/>
                        <Button Grid.Row="2"
                                Theme="{StaticResource M3SegmentedAmPmButton}"
                                Classes.Selected="{Binding !IsAm}"
                                Content="PM"
                                Command="{Binding SetAmPmCommand}"
                                CommandParameter="PM"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Dial -->
            <Grid Grid.Row="2"
                  Width="256" Height="256"
                  HorizontalAlignment="Center"
                  Margin="0,0,0,12">

                <Ellipse Fill="{DynamicResource SurfaceContainerHighest}"/>

                <Canvas Background="Transparent"
                        Width="256" Height="256"
                        PointerPressed="ClockCanvas_PointerPressed"
                        PointerMoved="ClockCanvas_PointerMoved"
                        PointerReleased="ClockCanvas_PointerReleased">

                    <!--
                        Hand: 124x48 horizontal grid. The rotation pivot is the
                        left-middle (CenterX=0, CenterY=24), positioned at the
                        dial center (128, 128). Stem 100dp + knob 48dp aligned
                        right means the knob's center sits at x=124-24=100,
                        i.e. 100dp from the pivot — exactly the radius the
                        CircularPanel uses for the digits (0.78 * 128 = 99.84).
                    -->
                    <Grid Width="124" Height="48"
                          Canvas.Left="128" Canvas.Top="104"
                          IsHitTestVisible="False">
                        <Grid.RenderTransform>
                            <RotateTransform Angle="{Binding HandAngle}" CenterX="0" CenterY="24">
                                <RotateTransform.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Angle"
                                                          Duration="{StaticResource M3DurationShort4}"
                                                          Easing="{StaticResource M3EasingStandard}"/>
                                    </Transitions>
                                </RotateTransform.Transitions>
                            </RotateTransform>
                        </Grid.RenderTransform>

                        <!-- Stem: 100dp from the pivot (left edge) up to the knob -->
                        <Rectangle Width="100" Height="2"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Fill="{DynamicResource Primary}"/>

                        <!-- Knob: 48dp circle at the far end (center sits at x=100) -->
                        <Ellipse Width="48" Height="48"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 Fill="{DynamicResource Primary}"/>
                    </Grid>

                    <!-- Center dot -->
                    <Ellipse Width="8" Height="8"
                             Canvas.Left="124" Canvas.Top="124"
                             Fill="{DynamicResource Primary}"
                             IsHitTestVisible="False"/>
                </Canvas>

                <!-- Hour ticks (1..12) -->
                <ItemsControl ItemsSource="{Binding HourTicks}"
                              IsVisible="{Binding IsHourMode}"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <utility:CircularPanel RadiusFactor="0.78" IndexPositionOffset="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="utility:ClockTickViewModel">
                            <Button Theme="{StaticResource M3ClockTick}"
                                    Classes.Selected="{Binding IsSelected}"
                                    Content="{Binding Display}"
                                    IsHitTestVisible="False"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Minute ticks (0,5,10,...,55) -->
                <ItemsControl ItemsSource="{Binding MinuteTicks}"
                              IsVisible="{Binding IsMinuteMode}"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <utility:CircularPanel RadiusFactor="0.78"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="utility:ClockTickViewModel">
                            <Button Theme="{StaticResource M3ClockTick}"
                                    Classes.Selected="{Binding IsSelected}"
                                    Content="{Binding Display}"
                                    IsHitTestVisible="False"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Actions -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Classes="Text"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"/>
                <Button Classes="Text"
                        Content="OK"
                        Command="{Binding ConfirmCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
