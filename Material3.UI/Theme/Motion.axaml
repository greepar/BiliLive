<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <!--
        Material 3 motion tokens.
        Reference: https://m3.material.io/styles/motion/easing-and-duration/tokens-specs.

        Easing curves below approximate the M3 cubic-bezier specification.
        Avalonia exposes these via SplineEasing which takes (X1,Y1) (X2,Y2).
    -->

    <!-- Standard set: most common easing for in/out transitions. -->
    <SplineEasing x:Key="M3EasingStandard" X1="0.2" Y1="0" X2="0" Y2="1" />
    <SplineEasing x:Key="M3EasingStandardDecelerate" X1="0" Y1="0" X2="0" Y2="1" />
    <SplineEasing x:Key="M3EasingStandardAccelerate" X1="0.3" Y1="0" X2="1" Y2="1" />

    <!-- Emphasized set: used to draw attention or for large transitions. -->
    <SplineEasing x:Key="M3EasingEmphasized" X1="0.2" Y1="0" X2="0" Y2="1" />
    <SplineEasing x:Key="M3EasingEmphasizedDecelerate" X1="0.05" Y1="0.7" X2="0.1" Y2="1" />
    <SplineEasing x:Key="M3EasingEmphasizedAccelerate" X1="0.3" Y1="0" X2="0.8" Y2="0.15" />

    <!-- Linear: rare; used by progress indicators. -->
    <LinearEasing x:Key="M3EasingLinear" />

    <!-- Duration tokens (TimeSpan). -->
    <sys:TimeSpan x:Key="M3DurationShort1">0:0:0.05</sys:TimeSpan>
    <sys:TimeSpan x:Key="M3DurationShort2">0:0:0.1</sys:TimeSpan>
    <sys:TimeSpan x:Key="M3DurationShort3">0:0:0.15</sys:TimeSpan>
    <sys:TimeSpan x:Key="M3DurationShort4">0:0:0.2</sys:TimeSpan>

    <sys:TimeSpan x:Key="M3DurationMedium1">0:0:0.25</sys:TimeSpan>
    <sys:TimeSpan x:Key="M3DurationMedium2">0:0:0.3</sys:TimeSpan>
    <sys:TimeSpan x:Key="M3DurationMedium3">0:0:0.35</sys:TimeSpan>
    <sys:TimeSpan x:Key="M3DurationMedium4">0:0:0.4</sys:TimeSpan>

    <sys:TimeSpan x:Key="M3DurationLong1">0:0:0.45</sys:TimeSpan>
    <sys:TimeSpan x:Key="M3DurationLong2">0:0:0.5</sys:TimeSpan>
    <sys:TimeSpan x:Key="M3DurationLong3">0:0:0.55</sys:TimeSpan>
    <sys:TimeSpan x:Key="M3DurationLong4">0:0:0.6</sys:TimeSpan>

    <sys:TimeSpan x:Key="M3DurationExtraLong1">0:0:0.7</sys:TimeSpan>
    <sys:TimeSpan x:Key="M3DurationExtraLong2">0:0:0.8</sys:TimeSpan>
    <sys:TimeSpan x:Key="M3DurationExtraLong3">0:0:0.9</sys:TimeSpan>
    <sys:TimeSpan x:Key="M3DurationExtraLong4">0:0:1.0</sys:TimeSpan>

</ResourceDictionary>
