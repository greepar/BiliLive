<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Material 3 elevation tokens.
        Reference: https://m3.material.io/styles/elevation/tokens.

        BoxShadow strings encode "OffsetX OffsetY BlurRadius SpreadRadius Color".
        Each level uses two layered shadows in M3 spec; we simplify to one
        shadow per level which renders well in Avalonia. The colors use
        15-30% alpha black to approximate the M3 ambient + key shadow look.
    -->

    <!-- Levels: 0 (no shadow) through 5 -->
    <BoxShadows x:Key="M3Elevation0">0 0 0 0 #00000000</BoxShadows>
    <BoxShadows x:Key="M3Elevation1">0 1 2 0 #26000000, 0 1 3 1 #1A000000</BoxShadows>
    <BoxShadows x:Key="M3Elevation2">0 1 2 0 #26000000, 0 2 6 2 #1A000000</BoxShadows>
    <BoxShadows x:Key="M3Elevation3">0 1 3 0 #26000000, 0 4 8 3 #1A000000</BoxShadows>
    <BoxShadows x:Key="M3Elevation4">0 2 3 0 #26000000, 0 6 10 4 #1A000000</BoxShadows>
    <BoxShadows x:Key="M3Elevation5">0 4 4 0 #26000000, 0 8 12 6 #1A000000</BoxShadows>

</ResourceDictionary>
