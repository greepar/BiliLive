<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:m3="https://github.com/greepar/md3">
    <!--
        Material 3 Time Picker control themes.
        Spec: https://m3.material.io/components/time-pickers/specs

        Three siblings, all built on the same PartContainer + PartStateLayer + PartRipple
        skeleton as the M3 button family so the ripple/state-layer pipeline is consistent
        across the whole app:

          M3TimeFieldButton      96x80 numeric field, Classes="Selected" tints PrimaryContainer.
          M3SegmentedAmPmButton  AM/PM cell inside an Outline-bordered segmented container.
          M3ClockTick            48dp circular dial number, Classes="Selected" colors text OnPrimary.
    -->

    <Design.PreviewWith>
        <Border Background="{DynamicResource SurfaceContainerHigh}" Padding="24">
            <StackPanel Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Theme="{DynamicResource M3TimeFieldButton}" Classes="Selected" Content="02"/>
                    <TextBlock Text=":" FontSize="57" Foreground="{DynamicResource OnSurface}" VerticalAlignment="Center"/>
                    <Button Theme="{DynamicResource M3TimeFieldButton}" Content="42"/>
                </StackPanel>

                <Border BorderBrush="{DynamicResource Outline}" BorderThickness="1"
                        CornerRadius="8" Width="52" Height="80" ClipToBounds="True">
                    <Grid RowDefinitions="*,1,*">
                        <Button Grid.Row="0" Theme="{DynamicResource M3SegmentedAmPmButton}" Content="AM" Classes="Selected"/>
                        <Border Grid.Row="1" Background="{DynamicResource Outline}"/>
                        <Button Grid.Row="2" Theme="{DynamicResource M3SegmentedAmPmButton}" Content="PM"/>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Theme="{DynamicResource M3ClockTick}" Content="3"/>
                    <Button Theme="{DynamicResource M3ClockTick}" Classes="Selected" Content="2"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <!-- =====================================================================
         Time field (numeric hour / minute) — 96x80, 8dp corner, DisplayLarge text.
         "Selected" = the field whose value is currently being edited on the dial.
         ===================================================================== -->
    <ControlTheme x:Key="M3TimeFieldButton" TargetType="Button">
        <Setter Property="Width" Value="96"/>
        <Setter Property="Height" Value="80"/>
        <Setter Property="MinWidth" Value="96"/>
        <Setter Property="MinHeight" Value="80"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="57"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceContainerHighest}"/>
        <Setter Property="Foreground" Value="{DynamicResource OnSurface}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ClipToBounds" Value="False"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PartContainer"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Panel ClipToBounds="True">
                        <Border Name="PartStateLayer"
                                IsHitTestVisible="False"
                                Opacity="0"
                                CornerRadius="{TemplateBinding CornerRadius}"/>
                        <m3:InkRipple Name="PartRipple"
                                      Brush="{TemplateBinding Foreground}"
                                      CornerRadius="{TemplateBinding CornerRadius}"
                                      BaseOpacity="{StaticResource M3StatePressedOpacity}"/>
                        <ContentPresenter Name="PartContent"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontFamily="{TemplateBinding FontFamily}"
                                          FontSize="{TemplateBinding FontSize}"
                                          FontWeight="{TemplateBinding FontWeight}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ Border#PartContainer">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="{StaticResource M3DurationShort2}"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="^ /template/ ContentPresenter#PartContent">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="{StaticResource M3DurationShort2}"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="^ /template/ Border#PartStateLayer">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="{StaticResource M3DurationShort2}"
                                      Easing="{StaticResource M3EasingStandard}"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="^.Selected">
            <Setter Property="Background" Value="{DynamicResource PrimaryContainer}"/>
            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryContainer}"/>
        </Style>

        <Style Selector="^:pointerover /template/ Border#PartStateLayer">
            <Setter Property="Background" Value="{DynamicResource OnSurface}"/>
            <Setter Property="Opacity" Value="{StaticResource M3StateHoverOpacity}"/>
        </Style>
        <Style Selector="^:pressed /template/ Border#PartStateLayer">
            <Setter Property="Background" Value="{DynamicResource OnSurface}"/>
            <Setter Property="Opacity" Value="{StaticResource M3StatePressedOpacity}"/>
        </Style>

        <Style Selector="^.Selected:pointerover /template/ Border#PartStateLayer">
            <Setter Property="Background" Value="{DynamicResource OnPrimaryContainer}"/>
            <Setter Property="Opacity" Value="{StaticResource M3StateHoverOpacity}"/>
        </Style>
        <Style Selector="^.Selected:pressed /template/ Border#PartStateLayer">
            <Setter Property="Background" Value="{DynamicResource OnPrimaryContainer}"/>
            <Setter Property="Opacity" Value="{StaticResource M3StatePressedOpacity}"/>
        </Style>
    </ControlTheme>

    <!-- =====================================================================
         AM/PM segmented cell. The host Border supplies the 1dp Outline frame
         and the splitting line; this theme just paints the active surface.
         ===================================================================== -->
    <ControlTheme x:Key="M3SegmentedAmPmButton" TargetType="Button">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariant}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ClipToBounds" Value="False"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PartContainer"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Panel ClipToBounds="True">
                        <Border Name="PartStateLayer"
                                IsHitTestVisible="False"
                                Opacity="0"
                                CornerRadius="{TemplateBinding CornerRadius}"/>
                        <m3:InkRipple Name="PartRipple"
                                      Brush="{TemplateBinding Foreground}"
                                      CornerRadius="{TemplateBinding CornerRadius}"
                                      BaseOpacity="{StaticResource M3StatePressedOpacity}"/>
                        <ContentPresenter Name="PartContent"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontFamily="{TemplateBinding FontFamily}"
                                          FontSize="{TemplateBinding FontSize}"
                                          FontWeight="{TemplateBinding FontWeight}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ Border#PartContainer">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="{StaticResource M3DurationShort2}"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="^ /template/ ContentPresenter#PartContent">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="{StaticResource M3DurationShort2}"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="^ /template/ Border#PartStateLayer">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="{StaticResource M3DurationShort2}"
                                      Easing="{StaticResource M3EasingStandard}"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="^.Selected">
            <Setter Property="Background" Value="{DynamicResource TertiaryContainer}"/>
            <Setter Property="Foreground" Value="{DynamicResource OnTertiaryContainer}"/>
        </Style>

        <Style Selector="^:pointerover /template/ Border#PartStateLayer">
            <Setter Property="Background" Value="{DynamicResource OnSurfaceVariant}"/>
            <Setter Property="Opacity" Value="{StaticResource M3StateHoverOpacity}"/>
        </Style>
        <Style Selector="^:pressed /template/ Border#PartStateLayer">
            <Setter Property="Background" Value="{DynamicResource OnSurfaceVariant}"/>
            <Setter Property="Opacity" Value="{StaticResource M3StatePressedOpacity}"/>
        </Style>

        <Style Selector="^.Selected:pointerover /template/ Border#PartStateLayer">
            <Setter Property="Background" Value="{DynamicResource OnTertiaryContainer}"/>
            <Setter Property="Opacity" Value="{StaticResource M3StateHoverOpacity}"/>
        </Style>
        <Style Selector="^.Selected:pressed /template/ Border#PartStateLayer">
            <Setter Property="Background" Value="{DynamicResource OnTertiaryContainer}"/>
            <Setter Property="Opacity" Value="{StaticResource M3StatePressedOpacity}"/>
        </Style>
    </ControlTheme>

    <!-- =====================================================================
         Clock dial number — 48dp circle. Selected cells flip Foreground to
         OnPrimary so the digit reads correctly under the dial's Primary knob.
         ===================================================================== -->
    <ControlTheme x:Key="M3ClockTick" TargetType="Button">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="MinWidth" Value="48"/>
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="24"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource OnSurface}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ClipToBounds" Value="False"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PartContainer"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Panel ClipToBounds="True">
                        <Border Name="PartStateLayer"
                                IsHitTestVisible="False"
                                Opacity="0"
                                CornerRadius="{TemplateBinding CornerRadius}"/>
                        <m3:InkRipple Name="PartRipple"
                                      Brush="{TemplateBinding Foreground}"
                                      CornerRadius="{TemplateBinding CornerRadius}"
                                      BaseOpacity="{StaticResource M3StatePressedOpacity}"/>
                        <ContentPresenter Name="PartContent"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Foreground="{TemplateBinding Foreground}"
                                          FontFamily="{TemplateBinding FontFamily}"
                                          FontSize="{TemplateBinding FontSize}"
                                          FontWeight="{TemplateBinding FontWeight}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^ /template/ ContentPresenter#PartContent">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="{StaticResource M3DurationShort2}"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="^ /template/ Border#PartStateLayer">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity"
                                      Duration="{StaticResource M3DurationShort2}"
                                      Easing="{StaticResource M3EasingStandard}"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="^.Selected">
            <Setter Property="Foreground" Value="{DynamicResource OnPrimary}"/>
        </Style>

        <Style Selector="^:pointerover /template/ Border#PartStateLayer">
            <Setter Property="Background" Value="{DynamicResource OnSurface}"/>
            <Setter Property="Opacity" Value="{StaticResource M3StateHoverOpacity}"/>
        </Style>
        <Style Selector="^:pressed /template/ Border#PartStateLayer">
            <Setter Property="Background" Value="{DynamicResource OnSurface}"/>
            <Setter Property="Opacity" Value="{StaticResource M3StatePressedOpacity}"/>
        </Style>
    </ControlTheme>
</ResourceDictionary>
