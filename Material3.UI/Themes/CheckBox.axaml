<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Material 3 CheckBox.
        Reference: https://m3.material.io/components/checkbox/specs

        - 18x18 box, 2px border, 2px corner radius
        - Unchecked: transparent fill, OnSurfaceVariant border, no glyph
        - Checked: filled with Primary, white check mark, no border
        - Indeterminate: filled with Primary, horizontal dash glyph
        - 40x40 hit target with circular Primary state layer (hover/pressed)
        - Disabled: OnSurface tinted at the M3 disabled opacities; check Surface
        - Label uses LabelLarge type with an 8px gap from the box
    -->

    <Design.PreviewWith>
        <Border Background="{DynamicResource Surface}" Padding="20">
            <StackPanel Spacing="6">
                <CheckBox>Unchecked</CheckBox>
                <CheckBox IsChecked="True">Checked</CheckBox>
                <CheckBox IsThreeState="True" IsChecked="{x:Null}">Indeterminate</CheckBox>
                <CheckBox IsEnabled="False">Disabled unchecked</CheckBox>
                <CheckBox IsEnabled="False" IsChecked="True">Disabled checked</CheckBox>
                <CheckBox Theme="{DynamicResource MdCheckBox}">MdCheckBox alias</CheckBox>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type CheckBox}" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource OnSurface}" />
        <Setter Property="FontFamily" Value="{DynamicResource M3FontDefault}" />
        <Setter Property="FontSize" Value="{StaticResource M3LabelLargeFontSize}" />
        <Setter Property="FontWeight" Value="{StaticResource M3LabelLargeFontWeight}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />

        <Setter Property="Template">
            <ControlTemplate>
                <Grid x:Name="RootGrid" ColumnDefinitions="40,*">
                    <!-- 40x40 hit target with state layer + 18x18 visible box -->
                    <Grid Width="40" Height="40"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center">
                        <Ellipse x:Name="StateLayer"
                                 Width="40" Height="40"
                                 Fill="{DynamicResource Primary}"
                                 Opacity="0"
                                 IsHitTestVisible="False" />
                        <Border x:Name="Box"
                                Width="18" Height="18"
                                BorderThickness="2"
                                CornerRadius="2"
                                BorderBrush="{DynamicResource OnSurfaceVariant}"
                                Background="Transparent"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        <Path x:Name="PART_CheckMark"
                              Width="12" Height="12"
                              Stretch="None"
                              Stroke="{DynamicResource OnPrimary}"
                              StrokeThickness="1.6"
                              StrokeJoin="Round"
                              StrokeLineCap="Round"
                              IsVisible="False"
                              IsHitTestVisible="False"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                    </Grid>

                    <!-- 8px visible gap between box (right edge at 29) and content (starts at 37) -->
                    <ContentPresenter x:Name="PART_ContentPresenter"
                                      Grid.Column="1"
                                      Margin="-3,0,0,0"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Foreground="{TemplateBinding Foreground}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      RecognizesAccessKey="True"
                                      TextWrapping="Wrap" />
                </Grid>
            </ControlTemplate>
        </Setter>

        <!-- Hover / pressed state layer (Primary tint) -->
        <Style Selector="^:pointerover /template/ Ellipse#StateLayer">
            <Setter Property="Opacity" Value="{StaticResource M3StateHoverOpacity}" />
        </Style>
        <Style Selector="^:pressed /template/ Ellipse#StateLayer">
            <Setter Property="Opacity" Value="{StaticResource M3StatePressedOpacity}" />
        </Style>

        <!-- Checked: filled Primary box, OnPrimary check glyph -->
        <Style Selector="^:checked /template/ Border#Box">
            <Setter Property="Background" Value="{DynamicResource Primary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
        </Style>
        <Style Selector="^:checked /template/ Path#PART_CheckMark">
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="Data" Value="M2 6 L5 9 L10 3" />
            <Setter Property="Stroke" Value="{DynamicResource OnPrimary}" />
        </Style>

        <!-- Indeterminate: filled Primary box, horizontal dash glyph -->
        <Style Selector="^:indeterminate /template/ Border#Box">
            <Setter Property="Background" Value="{DynamicResource Primary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Primary}" />
        </Style>
        <Style Selector="^:indeterminate /template/ Path#PART_CheckMark">
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="Data" Value="M2 6 L10 6" />
            <Setter Property="Stroke" Value="{DynamicResource OnPrimary}" />
        </Style>

        <!-- Disabled label (38% OnSurface) -->
        <Style Selector="^:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource OnSurface}" />
            <Setter Property="Opacity" Value="{StaticResource M3StateDisabledContentOpacity}" />
        </Style>

        <!-- Disabled unchecked: OnSurface border at 38% -->
        <Style Selector="^:disabled:unchecked /template/ Border#Box">
            <Setter Property="BorderBrush" Value="{DynamicResource OnSurface}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="{StaticResource M3StateDisabledContentOpacity}" />
        </Style>

        <!-- Disabled checked / indeterminate: OnSurface fill at 12%, glyph Surface -->
        <Style Selector="^:disabled:checked /template/ Border#Box">
            <Setter Property="Background" Value="{DynamicResource OnSurface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource OnSurface}" />
            <Setter Property="Opacity" Value="{StaticResource M3StateDisabledContainerOpacity}" />
        </Style>
        <Style Selector="^:disabled:indeterminate /template/ Border#Box">
            <Setter Property="Background" Value="{DynamicResource OnSurface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource OnSurface}" />
            <Setter Property="Opacity" Value="{StaticResource M3StateDisabledContainerOpacity}" />
        </Style>
        <Style Selector="^:disabled:checked /template/ Path#PART_CheckMark">
            <Setter Property="Stroke" Value="{DynamicResource Surface}" />
        </Style>
        <Style Selector="^:disabled:indeterminate /template/ Path#PART_CheckMark">
            <Setter Property="Stroke" Value="{DynamicResource Surface}" />
        </Style>

        <!-- Disabled also suppresses the state layer -->
        <Style Selector="^:disabled /template/ Ellipse#StateLayer">
            <Setter Property="Opacity" Value="0" />
        </Style>
    </ControlTheme>

    <!-- Backwards-compatible alias used by BiliLive code that hasn't been migrated yet. -->
    <ControlTheme x:Key="MdCheckBox" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}" />
</ResourceDictionary>
